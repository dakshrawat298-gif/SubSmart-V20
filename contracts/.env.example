# ─────────────────────────────────────────────────────────────────────────────
# SubSmart — Foundry environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Private key of the deployer EOA (0x-prefixed).
# On Amoy this wallet pays gas; fund it at https://faucet.polygon.technology/
PRIVATE_KEY=0x

# Polygon Amoy JSON-RPC endpoint.
# Free options: https://rpc-amoy.polygon.technology
#               https://polygon-amoy.g.alchemy.com/v2/<YOUR_ALCHEMY_KEY>
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Polygonscan API key — used only for source-code verification after deploy.
# Create a free key at https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=
