# ─────────────────────────────────────────────────────────────────────────────
# SubSmart Gelato Web3 Function — local test environment
# Copy to gelato/.env and fill in values.  Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# JSON map of chainId → RPC URL, consumed by the Gelato test runner.
# For Polygon Amoy (chainId 80002):
PROVIDER_URLS={"80002":"https://rpc-amoy.polygon.technology"}

# ── User args passed during local testing ────────────────────────────────────
# The deployed BillingHub address on Amoy (from Phase 8 deployment).
BH_ADDRESS=0xf3c62478Ab04B74Dd059b9835308D2D20F8233bb

# The block number at which BillingHub was deployed.
# Find this in contracts/broadcast/Deploy.s.sol/80002/run-latest.json
# under receipts[0].blockNumber.
DEPLOY_BLOCK=0

# Maximum charge() calls per single run (default 10).
MAX_CHARGES_PER_RUN=10
